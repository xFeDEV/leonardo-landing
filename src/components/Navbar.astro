---
---

<header class="sticky top-0 z-50 bg-campana-morado shadow-lg">
  <nav class="max-w-7xl mx-auto flex items-center justify-between px-4 py-2 md:px-8" aria-label="Navegación principal">
    <!-- Logo (Left) -->
    <a href="/" class="flex-shrink-0" aria-label="Ir al inicio">
      <img src="/logo.PNG" alt="Leonardo - Logo de campaña" class="h-[60px] w-auto object-contain" />
    </a>

    <!-- Navigation Links (Center) — hidden on mobile -->
    <ul class="hidden md:flex items-center gap-8 text-white font-medium text-lg list-none m-0 p-0">
      <li>
        <a href="#campana" class="hover:text-campana-lima transition-colors duration-200 cursor-pointer">
          Campaña
        </a>
      </li>
      <li>
        <a href="#mi-vida" class="hover:text-campana-lima transition-colors duration-200 cursor-pointer">
          Mi vida
        </a>
      </li>
      <li>
        <a href="#propuestas" class="hover:text-campana-lima transition-colors duration-200 cursor-pointer">
          Tus propuestas
        </a>
      </li>
    </ul>

    <!-- Right side: CTA + Hamburger -->
    <div class="flex items-center gap-3">
      <!-- CTA Button -->
      <a
        href="https://www.instagram.com/leonardohuertag/"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-campana-lima text-campana-morado font-bold rounded-full px-6 py-2.5 text-base
               hover:scale-105 hover:shadow-xl active:scale-95
               transition-all duration-200 cursor-pointer
               inline-flex items-center gap-2"
        aria-label="Únete a la campaña"
      >
        ¡Únete!
      </a>

      <!-- Hamburger Button (Mobile only) -->
      <button
        id="menu-toggle"
        class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 cursor-pointer"
        aria-label="Abrir menú de navegación"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span class="hamburger-line block w-6 h-0.5 bg-white rounded-full transition-all duration-300 origin-center"></span>
        <span class="hamburger-line block w-6 h-0.5 bg-white rounded-full transition-all duration-300 origin-center"></span>
        <span class="hamburger-line block w-6 h-0.5 bg-white rounded-full transition-all duration-300 origin-center"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu (Hidden by default) -->
  <div
    id="mobile-menu"
    class="md:hidden max-h-0 overflow-hidden transition-all duration-300 ease-in-out bg-campana-morado/95 backdrop-blur-sm"
  >
    <ul class="flex flex-col items-center gap-4 py-6 text-white font-medium text-lg list-none m-0 p-0">
      <li>
        <a href="#campana" class="hover:text-campana-lima transition-colors duration-200 cursor-pointer mobile-link">
          Campaña
        </a>
      </li>
      <li>
        <a href="#mi-vida" class="hover:text-campana-lima transition-colors duration-200 cursor-pointer mobile-link">
          Mi vida
        </a>
      </li>
      <li>
        <a href="#propuestas" class="hover:text-campana-lima transition-colors duration-200 cursor-pointer mobile-link">
          Tus propuestas
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const lines = toggle?.querySelectorAll('.hamburger-line');
  const mobileLinks = menu?.querySelectorAll('.mobile-link');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('max-h-0');

    if (isOpen) {
      menu?.classList.remove('max-h-0');
      menu?.classList.add('max-h-60');
      toggle.setAttribute('aria-expanded', 'true');
      // Animate to X
      if (lines && lines.length === 3) {
        lines[0].style.transform = 'translateY(8px) rotate(45deg)';
        lines[1].style.opacity = '0';
        lines[2].style.transform = 'translateY(-8px) rotate(-45deg)';
      }
    } else {
      menu?.classList.add('max-h-0');
      menu?.classList.remove('max-h-60');
      toggle.setAttribute('aria-expanded', 'false');
      // Animate back to hamburger
      if (lines && lines.length === 3) {
        lines[0].style.transform = '';
        lines[1].style.opacity = '1';
        lines[2].style.transform = '';
      }
    }
  });

  // Close menu when a link is clicked
  mobileLinks?.forEach((link) => {
    link.addEventListener('click', () => {
      menu?.classList.add('max-h-0');
      menu?.classList.remove('max-h-60');
      toggle?.setAttribute('aria-expanded', 'false');
      if (lines && lines.length === 3) {
        lines[0].style.transform = '';
        lines[1].style.opacity = '1';
        lines[2].style.transform = '';
      }
    });
  });
</script>
