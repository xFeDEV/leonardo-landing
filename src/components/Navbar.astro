---
---

<header class="sticky top-0 z-50 bg-campana-morado shadow-lg">
  <nav class="max-w-7xl mx-auto flex items-center justify-between px-4 py-2 md:px-8" aria-label="Navegación principal">
    <!-- Logo (Left) -->
    <a href="/" class="flex-shrink-0" aria-label="Ir al inicio">
      <img src="/logo.PNG" alt="Leonardo - Logo de campaña" class="h-[60px] w-auto object-contain" />
    </a>

    <!-- Navigation Links (Center) -->
    <ul class="hidden md:flex items-center gap-8 text-white font-medium text-lg list-none m-0 p-0">
      <li>
        <a href="#campana" class="hover:text-campana-lima transition-colors duration-200 cursor-pointer">
          Campaña
        </a>
      </li>
      <li>
        <a href="#mi-vida" class="hover:text-campana-lima transition-colors duration-200 cursor-pointer">
          Mi vida
        </a>
      </li>
      <li>
        <a href="#propuestas" class="hover:text-campana-lima transition-colors duration-200 cursor-pointer">
          Tus propuestas
        </a>
      </li>
    </ul>

    <!-- CTA Button (Right) -->
    <a
      href="#unete"
      class="bg-campana-lima text-campana-morado font-bold rounded-full px-6 py-2.5 text-base
             hover:scale-105 hover:shadow-xl active:scale-95
             transition-all duration-200 cursor-pointer
             inline-flex items-center gap-2"
      aria-label="Únete a la campaña"
    >
      ¡Únete!
    </a>
  </nav>
</header>
